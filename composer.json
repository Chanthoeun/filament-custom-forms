{
    "name": "laraspace/filament-custom-forms",
    "description": "A FilamentPHP plugin to manage and submit custom forms with approval workflow.",
    "keywords": [
        "laravel",
        "filament",
        "plugin",
        "custom-forms"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "LaraSpace",
            "email": "info@laraspace.com"
        }
    ],
    "homepage": "https://github.com/laraspace/filament-custom-forms",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0|^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "LaraSpace\\FilamentCustomForms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraSpace\\FilamentCustomForms\\CustomFormServiceProvider"
            ]
        }
    }
}